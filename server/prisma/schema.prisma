generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN       // Quản trị viên hệ thống
  MANAGER     // Quản lý chung cư
  STAFF       // Nhân viên (bảo vệ, kỹ thuật...)
  TENANT      // Người thuê (cư dân)
}

model User {
  id           String   @id @default(uuid())
  email        String?   @unique
  passwordHash String
  role         UserRole   @default(TENANT)
  firstName    String?
  lastName     String?
  phone        String   @unique
  avatarUrl    String?
  faceId       String?  @unique
  isActive     Boolean  @default(true)
  
  
  updatedAt    DateTime @updatedAt @map("updateAt") 
  createdAt    DateTime @default(now())

  @@map("users")
}